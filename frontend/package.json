{
  "name": "tku-planner-react-connected",
  "private": true,
  "version": "1.0.0-alpha.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1",
    "dev:host": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 127.0.0.1",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2025-12-01"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "axios": "^1.13.2",
    "framer-motion": "^12.23.24",
    "react-router-dom": "^7.10.0",
    "@neondatabase/serverless": "^1.0.2"
  },
  "devDependencies": {}
}
